# ============================================================
# Base Image
# ============================================================
FROM python:3.11-slim

# ============================================================
# Working Directory
# ============================================================
WORKDIR /app

# ============================================================
# Install Dependencies
# ============================================================
COPY requirements.txt .

RUN pip install --no-cache-dir -r requirements.txt

# ============================================================
# Copy Project
# ============================================================
COPY . .

# ============================================================
# Run Application
# ============================================================
CMD ["python", "src/main.py"]